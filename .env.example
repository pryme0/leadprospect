NEXT_PUBLIC_API_URL=http://localhost:3003

# Google Tag Manager container ID. Loads the GTM container into <head>
# at build time — NEXT_PUBLIC_* vars are baked into the client bundle by
# Next.js, so you must rebuild the frontend after changing this.
NEXT_PUBLIC_GTM_ID=GTM-W9NFPZZ
REDDIT_BRAND_SUBREDDIT=excelmindcyber